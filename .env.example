# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# Ücretsiz BLS API anahtarı için: https://data.bls.gov/registrationEngine/

BLS_API_KEY=buraya_kendi_anahtarinizi_yazin

# Opsiyonel: Veritabanı dosyasını farklı bir konuma (örn. Dropbox/OneDrive
# senkronize klasörü) yönlendirmek isterseniz aşağıdaki satırı açın.
# DB_PATH=/Users/kullanici/Dropbox/bls_data/employment.db
